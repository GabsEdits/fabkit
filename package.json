{
  "name": "fabkit",
  "version": "0.0.6",
  "scripts": {
    "build": "rollup -c",
    "prepublishOnly": "svelte-kit sync && svelte-package && rollup -c",
    "check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json --watch",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "files": [
    "dist",
    "types",
    "!dist/**/*.test.*",
    "src/lib/components",
    "src/lib",
    "src",
    "!dist/**/*.spec.*"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "svelte": "./src/lib/index.js",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "svelte": "./src/lib/index.js",
      "import": "./dist/index.mjs",
      "default": "./dist/index.js"
    },
    "./EngineContext": {
      "types": "./types/EngineContext.d.ts",
      "import": "./dist/EngineContext.mjs",
      "default": "./dist/EngineContext.js"
    },
    "./engines/Browser": {
      "types": "./types/engines/Browser.d.ts",
      "import": "./dist/engines/Browser.mjs",
      "default": "./dist/engines/Browser.js"
    }
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.3",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@storybook/addon-a11y": "^10.1.7",
    "@storybook/addon-docs": "^10.1.7",
    "@storybook/addon-svelte-csf": "^5.0.10",
    "@storybook/addon-vitest": "^10.1.7",
    "@storybook/svelte": "^10.1.7",
    "@storybook/sveltekit": "^10.1.7",
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/kit": "^2.48.5",
    "rollup": "^4.12.0",
    "rollup-plugin-svelte": "^7.1.5",
    "rollup-plugin-terser": "^7.0.2",
    "@vitest/browser-playwright": "^4.0.15",
    "@vitest/coverage-v8": "^4.0.15",
    "playwright": "^1.57.0",
    "sass": "^1.96.0",
    "storybook": "^10.1.7",
    "svelte": "^5.43.8",
    "svelte-check": "^4.3.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "keywords": [
    "svelte"
  ],
  "dependencies": {
    "mitt": "^3.0.1"
  }
}
